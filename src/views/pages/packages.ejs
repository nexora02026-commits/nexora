<script>
(function(){
  /* Scroll reveal */
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); }
    });
  }, { threshold: .1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.pkg-reveal, .p-card').forEach(el => {
    if (el.classList.contains('p-card')) {
      const revIo = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); revIo.unobserve(e.target); }
        });
      }, { threshold: .1 });
      revIo.observe(el);
    } else {
      io.observe(el);
    }
  });

  /* 3D tilt on cards */
  document.querySelectorAll('[data-tilt]').forEach(card => {
    const MAX = 9;
    card.addEventListener('mousemove', e => {
      const r  = card.getBoundingClientRect();
      const x  = e.clientX - r.left - r.width / 2;
      const y  = e.clientY - r.top  - r.height / 2;
      const rx =  (y / (r.height / 2)) * MAX;
      const ry = -(x / (r.width  / 2)) * MAX;
      card.style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(8px)`;
    });
    card.addEventListener('mouseleave', () => {
      const isFeat = card.classList.contains('featured');
      card.style.transition = 'transform .6s cubic-bezier(0.34,1.56,0.64,1)';
      card.style.transform  = isFeat ? 'translateY(-10px)' : '';
      setTimeout(() => { card.style.transition = ''; }, 650);
    });
  });
})();
</script>

