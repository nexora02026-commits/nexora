<%- include('../partials/header') %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap');

/* ═══════════════════════════════════════════════════════════
   BRAND TOKENS — exact match to site :root
   ═══════════════════════════════════════════════════════════ */
.pkg-page {
  --ink:      #080d1a;
  --ink2:     #0f1d3a;
  --sky:      #00d4ff;
  --sky2:     #00aacc;
  --violet:   #7b5cf0;
  --violet2:  #5c3fc0;
  --violet3:  #4a2fa8;
  --surface:  #f4f6ff;
  --surface2: #eef0fc;
  --card:     #ffffff;
  --muted:    #64748b;
  --muted2:   #94a3b8;
  --border:   rgba(123,92,240,.12);
  --border2:  rgba(123,92,240,.22);
  --r:        16px;
  --r2:       24px;
  --sh:       0 4px 24px rgba(0,0,0,.06), 0 1px 4px rgba(0,0,0,.04);
  --shm:      0 8px 40px rgba(0,0,0,.10), 0 2px 8px rgba(0,0,0,.05);
  --shl:      0 20px 60px rgba(0,0,0,.14), 0 4px 16px rgba(0,0,0,.06);
  --glow-sky: 0 0 40px rgba(0,212,255,.25);
  --glow-v:   0 0 40px rgba(123,92,240,.3);
  --trans:    all .3s cubic-bezier(.4,0,.2,1);
  --trans-f:  all .18s cubic-bezier(.4,0,.2,1);

  /* Extended tokens for this page */
  --ease-spring: cubic-bezier(0.34,1.56,0.64,1);
  --ease-out:    cubic-bezier(0.16,1,0.3,1);

  font-family: 'DM Sans', system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
}
.pkg-page *, .pkg-page *::before, .pkg-page *::after { box-sizing: border-box; }
.pkg-page h1,.pkg-page h2,.pkg-page h3,.pkg-page h4,.pkg-page h5 {
  font-family: 'Syne', sans-serif;
}

/* ═══════════════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════════════ */
.pkg-hero {
  position: relative;
  background: var(--ink);
  padding: 9rem 2rem 8rem;
  text-align: center;
  overflow: hidden;
}

/* Layered mesh gradients */
.pkg-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 20% 0%,   rgba(123,92,240,.18) 0%, transparent 60%),
    radial-gradient(ellipse 50% 50% at 80% 100%,  rgba(0,212,255,.14) 0%, transparent 55%),
    radial-gradient(ellipse 40% 70% at 90% 20%,   rgba(123,92,240,.08) 0%, transparent 50%);
  pointer-events: none;
}

/* Grid lines */
.pkg-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(123,92,240,.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(123,92,240,.06) 1px, transparent 1px);
  background-size: 64px 64px;
  pointer-events: none;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
}

/* Floating orbs */
.pkg-hero-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(80px);
}
.pkg-hero-orb-1 {
  width: 500px; height: 500px;
  top: -200px; left: -100px;
  background: rgba(123,92,240,.12);
  animation: orb-drift 12s ease-in-out infinite;
}
.pkg-hero-orb-2 {
  width: 400px; height: 400px;
  bottom: -150px; right: -80px;
  background: rgba(0,212,255,.10);
  animation: orb-drift 15s ease-in-out infinite reverse;
}
.pkg-hero-orb-3 {
  width: 300px; height: 300px;
  top: 30%; left: 55%;
  background: rgba(123,92,240,.07);
  animation: orb-drift 10s ease-in-out infinite 3s;
}
@keyframes orb-drift {
  0%,100% { transform: translate(0, 0) scale(1); }
  33%      { transform: translate(30px, -20px) scale(1.08); }
  66%      { transform: translate(-20px, 15px) scale(.94); }
}

.pkg-hero-content { position: relative; z-index: 2; }

.pkg-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .35rem 1.1rem;
  border: 1px solid rgba(0,212,255,.3);
  border-radius: 999px;
  font-family: 'Syne', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--sky);
  background: rgba(0,212,255,.06);
  margin-bottom: 1.75rem;
  animation: fade-up .8s var(--ease-out) both;
}
.pkg-eyebrow-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--sky);
  box-shadow: 0 0 8px var(--sky);
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%,100% { transform: scale(1); opacity:1; }
  50%      { transform: scale(1.4); opacity:.6; }
}

.pkg-hero h1 {
  font-size: clamp(2.8rem, 6.5vw, 5rem);
  font-weight: 800;
  letter-spacing: -.04em;
  line-height: .95;
  color: #fff;
  margin-bottom: 1.5rem;
  animation: fade-up .9s .1s var(--ease-out) both;
}

/* Gradient text span */
.pkg-hero h1 .grad {
  background: linear-gradient(135deg, var(--sky) 0%, var(--violet) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
}

.pkg-hero p {
  font-size: 1.05rem;
  color: rgba(255,255,255,.5);
  max-width: 480px;
  margin: 0 auto;
  line-height: 1.8;
  animation: fade-up .9s .2s var(--ease-out) both;
}

/* Scroll hint */
.pkg-hero-scroll {
  position: absolute;
  bottom: 2.5rem; left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .4rem;
  opacity: .3;
  animation: fade-up .9s .5s var(--ease-out) both;
}
.pkg-hero-scroll span {
  font-size: .62rem;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: #fff;
}
.pkg-scroll-track {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, rgba(0,212,255,.8), transparent);
  animation: track-drop 2.2s ease-in-out infinite;
  transform-origin: top;
}
@keyframes track-drop {
  0%   { transform: scaleY(0); opacity:0; }
  30%  { opacity:1; }
  70%  { transform: scaleY(1); opacity:1; }
  100% { transform: scaleY(1); opacity:0; }
}

@keyframes fade-up {
  from { opacity:0; transform:translateY(22px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ═══════════════════════════════════════════════════════════
   PRICING CARDS
   ═══════════════════════════════════════════════════════════ */
.pricing-section {
  background: var(--surface);
  padding: 6rem 2rem 7rem;
  position: relative;
  overflow: hidden;
}

/* Subtle top accent */
.pricing-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--violet), var(--sky), var(--violet), transparent);
}

/* Background mesh */
.pricing-section::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 55% 40% at 10% 80%, rgba(123,92,240,.06) 0%, transparent 60%),
    radial-gradient(ellipse 45% 50% at 90% 20%, rgba(0,212,255,.05) 0%, transparent 60%);
  pointer-events: none;
}

.pricing-inner {
  max-width: 1160px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.pricing-grid {
  display: grid;
  grid-template-columns: 1fr 1.05fr 1fr;
  gap: 1.5rem;
  align-items: start;
}

/* ── Card base ── */
.p-card {
  position: relative;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: var(--r2);
  padding: 2.25rem 2rem;
  box-shadow: var(--sh);
  transition: var(--trans);
  overflow: hidden;
  opacity: 0;
  transform: translateY(28px);
}
.p-card.visible { animation: card-rise .65s var(--ease-out) forwards; }
.p-card:nth-child(1).visible { animation-delay: 0s; }
.p-card:nth-child(2).visible { animation-delay: .12s; }
.p-card:nth-child(3).visible { animation-delay: .22s; }

@keyframes card-rise {
  to { opacity:1; transform:translateY(0); }
}

/* Top shimmer line */
.p-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--violet), transparent);
  opacity: 0;
  transition: opacity .3s;
}
.p-card:hover::before { opacity:1; }

.p-card:hover {
  box-shadow: var(--shm);
  border-color: var(--border2);
  transform: translateY(-6px);
}

/* Inner glow on hover */
.p-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(123,92,240,.04) 0%, transparent 70%);
  opacity: 0;
  transition: opacity .4s;
  pointer-events: none;
  border-radius: inherit;
}
.p-card:hover::after { opacity: 1; }

/* ── Featured card ── */
.p-card.featured {
  background: linear-gradient(155deg, var(--ink2) 0%, var(--ink) 100%);
  border-color: rgba(123,92,240,.35);
  box-shadow: var(--shl), var(--glow-v);
  transform: translateY(-10px);
  z-index: 2;
}
.p-card.featured::before {
  background: linear-gradient(90deg, transparent, var(--sky), var(--violet), var(--sky), transparent);
  opacity: 1;
  animation: top-shimmer 3s linear infinite;
  background-size: 300% 100%;
}
@keyframes top-shimmer {
  0%   { background-position: 150% 0; }
  100% { background-position: -150% 0; }
}
.p-card.featured::after {
  background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0,212,255,.07) 0%, transparent 70%);
  opacity: 1;
}
.p-card.featured:hover {
  transform: translateY(-18px);
  box-shadow: 0 40px 100px rgba(0,0,0,.25), var(--glow-v), var(--glow-sky);
  border-color: rgba(0,212,255,.4);
}

/* Badge */
.feat-badge {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  padding: .3rem .9rem;
  background: linear-gradient(135deg, var(--violet), var(--violet2));
  color: #fff;
  font-family: 'Syne', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: 999px;
  margin-bottom: 1.5rem;
  box-shadow: var(--glow-v);
}

.pkg-tier {
  font-family: 'Syne', sans-serif;
  font-size: .63rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--muted2);
  margin-bottom: .5rem;
}
.p-card.featured .pkg-tier { color: rgba(0,212,255,.6); }

.pkg-name {
  font-family: 'Syne', sans-serif;
  font-size: 2.2rem;
  font-weight: 800;
  letter-spacing: -.04em;
  line-height: 1;
  color: var(--ink);
  margin-bottom: 1.1rem;
}
.p-card.featured .pkg-name {
  background: linear-gradient(135deg, var(--sky), var(--violet));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.pkg-price-block { margin-bottom: .5rem; }

.pkg-price {
  font-family: 'Syne', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -.03em;
  color: var(--violet);
}
.p-card.featured .pkg-price { color: var(--sky); }

.pkg-del {
  font-size: .74rem;
  color: var(--muted2);
  margin-top: .3rem;
  display: flex;
  align-items: center;
  gap: .3rem;
}
.p-card.featured .pkg-del { color: rgba(255,255,255,.35); }

.pkg-divider {
  height: 1px;
  background: var(--border);
  margin: 1.4rem 0;
}
.p-card.featured .pkg-divider { background: rgba(123,92,240,.25); }

.pkg-desc {
  font-size: .84rem;
  color: var(--muted);
  line-height: 1.75;
  margin-bottom: 1.5rem;
}
.p-card.featured .pkg-desc { color: rgba(255,255,255,.5); }

/* Feature list */
.pkg-feats {
  list-style: none;
  padding: 0; margin: 0 0 2rem;
  display: flex;
  flex-direction: column;
  gap: .6rem;
}
.pkg-feats li {
  display: flex;
  align-items: center;
  gap: .65rem;
  font-size: .82rem;
  color: var(--muted);
  line-height: 1.4;
}
.pkg-feats li::before {
  content: '';
  flex-shrink: 0;
  width: 18px; height: 18px;
  border-radius: 50%;
  border: 1.5px solid var(--border2);
  background: rgba(123,92,240,.05);
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='%237b5cf0' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
}
.p-card.featured .pkg-feats li { color: rgba(255,255,255,.65); }
.p-card.featured .pkg-feats li::before {
  border-color: rgba(0,212,255,.4);
  background-color: rgba(0,212,255,.07);
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='8' viewBox='0 0 10 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 4l2.5 2.5L9 1' stroke='%2300d4ff' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
}

/* Buttons */
.pkg-btn {
  display: block;
  width: 100%;
  text-align: center;
  padding: .875rem 1.5rem;
  border-radius: var(--r);
  font-family: 'Syne', sans-serif;
  font-size: .82rem;
  font-weight: 700;
  letter-spacing: .03em;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: var(--trans);
  position: relative;
  overflow: hidden;
}
.pkg-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0);
  transition: background .2s;
}
.pkg-btn:hover::after { background: rgba(255,255,255,.07); }
.pkg-btn:hover { transform: translateY(-2px); }
.pkg-btn:active { transform: translateY(0) scale(.98); }

.btn-violet {
  background: linear-gradient(135deg, var(--violet), var(--violet2));
  color: #fff;
  box-shadow: 0 4px 20px rgba(123,92,240,.35);
}
.btn-violet:hover {
  box-shadow: 0 8px 32px rgba(123,92,240,.5);
}

.btn-sky {
  background: linear-gradient(135deg, var(--sky), var(--sky2));
  color: var(--ink);
  box-shadow: 0 4px 20px rgba(0,212,255,.3);
  font-weight: 800;
}
.btn-sky:hover {
  box-shadow: var(--glow-sky), 0 8px 32px rgba(0,212,255,.25);
}

.btn-outline {
  background: transparent;
  border: 1.5px solid var(--border2);
  color: var(--violet);
}
.btn-outline:hover {
  border-color: var(--violet);
  background: rgba(123,92,240,.05);
  box-shadow: var(--glow-v);
}

/* ═══════════════════════════════════════════════════════════
   PAYMENT SECTION
   ═══════════════════════════════════════════════════════════ */
.payment-section {
  background: var(--ink);
  padding: 6rem 2rem;
  position: relative;
  overflow: hidden;
}

.payment-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 50% 70% at 0% 50%,   rgba(123,92,240,.12) 0%, transparent 60%),
    radial-gradient(ellipse 40% 60% at 100% 30%,  rgba(0,212,255,.09) 0%, transparent 55%),
    radial-gradient(ellipse 60% 40% at 50% 100%,  rgba(123,92,240,.06) 0%, transparent 55%);
  pointer-events: none;
}

/* Grid */
.payment-section::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(123,92,240,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(123,92,240,.04) 1px, transparent 1px);
  background-size: 64px 64px;
  pointer-events: none;
  mask-image: radial-gradient(ellipse 90% 90% at 50% 50%, black, transparent);
  -webkit-mask-image: radial-gradient(ellipse 90% 90% at 50% 50%, black, transparent);
}

.payment-inner {
  max-width: 1100px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.payment-banner {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 5rem;
  align-items: center;
}

/* Section eyebrow */
.eyebrow-dark {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .3rem 1rem;
  border: 1px solid rgba(0,212,255,.25);
  border-radius: 999px;
  font-family: 'Syne', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--sky);
  background: rgba(0,212,255,.06);
  margin-bottom: 1.25rem;
}

.payment-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 800;
  letter-spacing: -.04em;
  line-height: 1.1;
  color: #fff;
  margin-bottom: 1rem;
}
.payment-title .highlight {
  background: linear-gradient(135deg, var(--sky), var(--violet));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.payment-desc {
  font-size: .95rem;
  color: rgba(255,255,255,.45);
  line-height: 1.85;
  max-width: 500px;
  margin-bottom: 2.5rem;
}
.payment-desc strong { color: rgba(255,255,255,.8); font-weight: 600; }

/* Steps */
.payment-steps {
  display: flex;
  flex-direction: column;
  gap: .7rem;
}

.pay-step {
  display: flex;
  gap: 1.1rem;
  align-items: flex-start;
  padding: 1.1rem 1.35rem;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(123,92,240,.14);
  border-radius: var(--r);
  transition: var(--trans);
  position: relative;
  overflow: hidden;
}

/* Left accent bar */
.pay-step::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--sky), var(--violet));
  transform: scaleY(0);
  transform-origin: bottom;
  transition: transform .35s var(--ease-out);
  border-radius: 0 2px 2px 0;
}
.pay-step:hover::before { transform: scaleY(1); }

.pay-step:hover {
  background: rgba(255,255,255,.055);
  border-color: rgba(123,92,240,.3);
  box-shadow: 0 8px 30px rgba(0,0,0,.2);
  transform: translateX(6px);
}

.pay-step-num {
  flex-shrink: 0;
  width: 36px; height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--violet), var(--violet2));
  color: #fff;
  font-family: 'Syne', sans-serif;
  font-size: .78rem;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 14px rgba(123,92,240,.4);
}

.pay-step-body h5 {
  font-family: 'Syne', sans-serif;
  font-size: .87rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 .2rem;
  letter-spacing: -.01em;
}
.pay-step-body p {
  font-size: .78rem;
  color: rgba(255,255,255,.38);
  line-height: 1.55;
  margin: 0;
}

/* ── Vodafone Card ── */
.payment-badge-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
}

.vf-card {
  position: relative;
  width: 245px;
  padding: 2.5rem 1.75rem;
  background: rgba(255,255,255,.04);
  border: 1.5px solid rgba(123,92,240,.25);
  border-radius: var(--r2);
  box-shadow: var(--shl), var(--glow-v);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .85rem;
  overflow: hidden;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: transform .5s var(--ease-spring), box-shadow .5s var(--ease-out);
}

/* Animated gradient top stripe */
.vf-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--violet3), #e60000, #ff6666, #e60000, var(--violet3));
  background-size: 300% 100%;
  animation: vf-stripe 2.8s linear infinite;
}
@keyframes vf-stripe {
  0%   { background-position: 150% 0; }
  100% { background-position: -150% 0; }
}

/* Inner glow */
.vf-card::after {
  content: '';
  position: absolute;
  top: -60px; left: 50%;
  transform: translateX(-50%);
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(230,0,0,.1) 0%, transparent 70%);
  pointer-events: none;
}

.vf-card:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 0 40px 90px rgba(0,0,0,.4), 0 0 0 1px rgba(230,0,0,.25), var(--glow-v);
  border-color: rgba(230,0,0,.3);
